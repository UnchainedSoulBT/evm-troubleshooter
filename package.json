{
  "name": "evm-troubleshooter",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @evm-troubleshooter/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:fork": "vitest run --config vitest.fork.config.ts",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:e2e": "pnpm --filter e2e test"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint": "^9",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3",
    "@vitest/coverage-v8": "^3"
  }
}
